    {
      "cell_type": "code",
      "source": [
        "dados$tipo_acidente <- iconv(dados$tipo_acidente, from = \"latin1\", to = \"UTF-8\")\n",
        "\n",
        "# Criar tabela resumida\n",
        "tipos_acidente <- dados %>%\n",
        "  group_by(tipo_acidente) %>%\n",
        "  summarise(total = n()) %>%\n",
        "  arrange(desc(total))\n",
        "\n",
        "# Gráfico\n",
        "grafico_tipos <- ggplot(tipos_acidente, aes(x = reorder(tipo_acidente, -total), y = total)) +\n",
        "  geom_bar(stat = \"identity\") +\n",
        "  labs(title = \"Tipos de acidentes registrados\",\n",
        "       x = \"Tipo de acidente\",\n",
        "       y = \"Quantidade\") +\n",
        "  theme(axis.text.x = element_text(angle = 45, hjust = 1))\n",
        "\n",
        "grafico_tipos\n",
        "\n",
        "\n",
        "if(!dir.exists(\"outputs/graficos\")){\n",
        "  dir.create(\"outputs/graficos\", recursive = TRUE)\n",
        "}\n",
        "\n",
        "\n",
        "ggsave(\"outputs/graficos/tipos_acidente.png\", grafico_tipos, width = 10, height = 5)"
      ],
